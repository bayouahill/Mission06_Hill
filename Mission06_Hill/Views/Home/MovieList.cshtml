@model List<Movie>

@{
    ViewData["Title"] = "Film Collection";
}

<div class="fade-in-up">

    <!-- Page Header -->
    <div class="text-center mb-5">
        <h1 class="display-4">FILM COLLECTION</h1>
        <p class="lead" style="color: var(--text-muted); font-size: 1rem; letter-spacing: 2px;">
            [ @Model.Count TITLES IN ARCHIVE ]
        </p>
        <div style="width: 80px; height: 2px; background: linear-gradient(90deg, var(--neon-cyan), var(--neon-purple)); margin: 1.5rem auto;"></div>
    </div>

    <!-- Success Alert -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success text-center mb-4" role="alert">
            @TempData["Success"]
        </div>
    }

    <!-- Toolbar: Search + Add Button -->
    <div class="row align-items-center mb-4 g-3">
        <div class="col-md-8">
            <div class="input-group">
                <span class="input-group-text"
                      style="background: rgba(13,13,26,0.9); border: 2px solid rgba(0,255,255,0.4); border-right: none; color: var(--neon-cyan);">
                    &#128269;
                </span>
                <input type="text" id="searchBox" class="form-control"
                       placeholder="Search by title, director, category, rating..."
                       style="border-left: none;" />
            </div>
        </div>
        <div class="col-md-4 text-md-end">
            <a asp-action="MovieForm" class="btn btn-primary w-100 w-md-auto">
                &#43; ADD NEW FILM
            </a>
        </div>
    </div>

    <!-- Movie Table -->
    <div class="table-responsive">
        <table class="table table-dark table-hover table-bordered align-middle mb-0" id="movieTable">
            <thead>
                <tr>
                    <th scope="col">Title</th>
                    <th scope="col">Category</th>
                    <th scope="col">Year</th>
                    <th scope="col">Director</th>
                    <th scope="col" class="text-center">Rating</th>
                    <th scope="col" class="text-center">Edited</th>
                    <th scope="col" class="text-center">On Plex</th>
                    <th scope="col">Notes</th>
                    <th scope="col" class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var movie in Model)
                {
                    <tr>
                        <td style="font-weight: 500; color: var(--neon-cyan);">@movie.Title</td>
                        <td>@movie.Category?.CategoryName</td>
                        <td>@movie.Year</td>
                        <td>@movie.Director</td>
                        <td class="text-center">
                            @if (!string.IsNullOrEmpty(movie.Rating))
                            {
                                <span class="badge"
                                      style="background: rgba(0,255,255,0.15); color: var(--neon-cyan); border: 1px solid rgba(0,255,255,0.4); font-size: 0.8rem; letter-spacing: 1px;">
                                    @movie.Rating
                                </span>
                            }
                        </td>
                        <td class="text-center">
                            @if (movie.Edited)
                            {
                                <span style="color: var(--neon-pink); font-size: 1.1rem;" title="Edited">&#10003;</span>
                            }
                        </td>
                        <td class="text-center">
                            @if (movie.CopiedToPlex)
                            {
                                <span style="color: #00e5a0; font-size: 1.1rem;" title="On Plex">&#10003;</span>
                            }
                        </td>
                        <td style="color: var(--text-muted); font-size: 0.9rem;">@movie.Notes</td>
                        <td class="text-center" style="white-space: nowrap;">
                            <a asp-action="EditMovie" asp-route-id="@movie.MovieId"
                               class="btn btn-sm btn-outline-info me-1"
                               style="letter-spacing: 0.5px; padding: 0.3rem 0.8rem;">
                                EDIT
                            </a>
                            <button type="button"
                                    class="btn btn-sm btn-outline-danger"
                                    style="letter-spacing: 0.5px; padding: 0.3rem 0.8rem;"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deleteModal"
                                    data-movie-id="@movie.MovieId"
                                    data-movie-title="@movie.Title">
                                DELETE
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- No Results Message (hidden by default) -->
    <div id="noResults" class="text-center py-5" style="display: none !important;">
        <p style="color: var(--text-muted); font-size: 1.1rem; letter-spacing: 2px;">[ NO FILMS MATCH YOUR SEARCH ]</p>
    </div>

</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background: var(--dark-card); border: 2px solid rgba(255,0,128,0.6); box-shadow: 0 0 30px rgba(255,0,128,0.4);">
            <div class="modal-header" style="border-bottom: 1px solid rgba(255,0,128,0.3);">
                <h5 class="modal-title" id="deleteModalLabel"
                    style="color: var(--neon-pink); text-shadow: 0 0 10px rgba(255,0,128,0.6); letter-spacing: 2px;">
                    &#9888; CONFIRM DELETION
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body py-4">
                <p style="color: var(--text-light); font-size: 1rem; line-height: 1.7;">
                    Are you sure you want to remove
                    <strong id="movieTitleDisplay" style="color: var(--neon-cyan);"></strong>
                    from the archive?
                </p>
                <p style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 0;">
                    This action cannot be undone.
                </p>
            </div>
            <div class="modal-footer" style="border-top: 1px solid rgba(255,0,128,0.3);">
                <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal"
                        style="letter-spacing: 1px;">
                    CANCEL
                </button>
                <form id="deleteForm" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger" style="letter-spacing: 1px;">
                        CONFIRM DELETE
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // ── Live search filter ──────────────────────────────────────────────
        const searchBox = document.getElementById('searchBox');
        const tableBody = document.querySelector('#movieTable tbody');
        const noResults = document.getElementById('noResults');

        searchBox.addEventListener('input', function () {
            const filter = this.value.toLowerCase().trim();
            let visibleCount = 0;

            tableBody.querySelectorAll('tr').forEach(row => {
                const match = row.textContent.toLowerCase().includes(filter);
                row.style.display = match ? '' : 'none';
                if (match) visibleCount++;
            });

            noResults.style.setProperty('display', visibleCount === 0 ? 'block' : 'none', 'important');
        });

        // ── Delete modal: populate title and form action ────────────────────
        document.getElementById('deleteModal').addEventListener('show.bs.modal', function (event) {
            const btn = event.relatedTarget;
            const movieId = btn.getAttribute('data-movie-id');
            const movieTitle = btn.getAttribute('data-movie-title');

            document.getElementById('movieTitleDisplay').textContent = movieTitle;
            document.getElementById('deleteForm').action = '/Home/DeleteMovie/' + movieId;
        });
    </script>
}
