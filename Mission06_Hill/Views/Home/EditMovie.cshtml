@model MovieEntryForm

@{
    ViewData["Title"] = "Edit Film";
}

<div class="fade-in-up">

    <!-- Page Header -->
    <div class="text-center mb-5">
        <h1 class="display-4">EDIT FILM</h1>
        <p class="lead" style="color: var(--text-muted); font-size: 1rem; letter-spacing: 2px;">
            [ MODIFY FILM DATA IN ARCHIVE ]
        </p>
        <div style="width: 80px; height: 2px; background: linear-gradient(90deg, var(--neon-cyan), var(--neon-purple)); margin: 1.5rem auto;"></div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card p-4 p-md-5">
                <form asp-action="EditMovie" asp-route-id="@Model.MovieId" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-4">

                        <!-- Category -->
                        <div class="col-md-6">
                            <label asp-for="CategoryId" class="form-label">Category</label>
                            <select asp-for="CategoryId" asp-items="Model.CategoryOptions" class="form-select">
                                <option value="">-- Select Category --</option>
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger small"></span>
                        </div>

                        <!-- Title (required) -->
                        <div class="col-md-6">
                            <label asp-for="Title" class="form-label">
                                Title <span style="color: var(--neon-pink);">*</span>
                            </label>
                            <input asp-for="Title" class="form-control" placeholder="Film title" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <!-- Year (required, min 1888) -->
                        <div class="col-md-4">
                            <label asp-for="Year" class="form-label">
                                Year <span style="color: var(--neon-pink);">*</span>
                            </label>
                            <input asp-for="Year" type="number" class="form-control"
                                   placeholder="e.g. 1995"
                                   min="1888" max="2100" />
                            <span asp-validation-for="Year" class="text-danger small"></span>
                        </div>

                        <!-- Director -->
                        <div class="col-md-8">
                            <label asp-for="Director" class="form-label">Director</label>
                            <input asp-for="Director" class="form-control"
                                   list="directorList"
                                   placeholder="Enter director name"
                                   autocomplete="off" />
                            <datalist id="directorList">
                                @if (ViewBag.Directors != null)
                                {
                                    foreach (var name in (List<string>)ViewBag.Directors)
                                    {
                                        <option value="@name" />
                                    }
                                }
                            </datalist>
                        </div>

                        <!-- Rating -->
                        <div class="col-md-4">
                            <label asp-for="Rating" class="form-label">Rating</label>
                            <select asp-for="Rating" asp-items="ViewBag.Ratings" class="form-select">
                                <option value="">-- Select Rating --</option>
                            </select>
                        </div>

                        <!-- Edited (required) -->
                        <div class="col-md-4">
                            <label asp-for="Edited" class="form-label">
                                Edited? <span style="color: var(--neon-pink);">*</span>
                            </label>
                            <select asp-for="Edited" class="form-select">
                                <option value="false">No</option>
                                <option value="true">Yes</option>
                            </select>
                        </div>

                        <!-- Copied to Plex (required) -->
                        <div class="col-md-4">
                            <label asp-for="CopiedToPlex" class="form-label">
                                Copied to Plex? <span style="color: var(--neon-pink);">*</span>
                            </label>
                            <select asp-for="CopiedToPlex" class="form-select">
                                <option value="false">No</option>
                                <option value="true">Yes</option>
                            </select>
                        </div>

                        <!-- Lent To -->
                        <div class="col-md-6">
                            <label asp-for="LentTo" class="form-label">Lent to</label>
                            <input asp-for="LentTo" class="form-control" placeholder="Person's name (optional)" />
                        </div>

                        <!-- Notes -->
                        <div class="col-md-6">
                            <label asp-for="Notes" class="form-label">Notes <small style="color: var(--text-muted);">(max 25 chars)</small></label>
                            <input asp-for="Notes" class="form-control" placeholder="e.g. Plex, Blu-ray..." maxlength="25" />
                            <span asp-validation-for="Notes" class="text-danger small"></span>
                        </div>

                        <!-- Required legend -->
                        <div class="col-12">
                            <small style="color: var(--text-muted);">
                                <span style="color: var(--neon-pink);">*</span> Required fields
                            </small>
                        </div>

                        <!-- Buttons -->
                        <div class="col-12 text-center mt-2">
                            <button type="submit" class="btn btn-primary btn-lg px-5">
                                <span style="font-size: 1.1rem;">&#128190;</span> SAVE CHANGES
                            </button>
                            <a asp-action="MovieList" class="btn btn-outline-light btn-lg ms-3 px-5"
                               style="border-color: var(--text-muted); color: var(--text-muted);">
                                CANCEL
                            </a>
                        </div>

                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
